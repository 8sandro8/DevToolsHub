						"method": "PUT",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "Authorization",
								"value": "Bearer {{token}}"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"React (Actualizado)\",\n  \"rating\": 5,\n  \"es_favorito\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/tools/1",
							"host": ["{{baseUrl}}"],
