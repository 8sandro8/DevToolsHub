{
  "info": {
    "name": "DevToolsHub API",
    "description": "Colección completa de endpoints para la API de DevToolsHub\n\nURL Base: {{base_url}}\n\nAutenticación: Bearer token en header Authorization",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:4001",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sandrodev\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          },
          "description": "Registra un nuevo usuario en el sistema"
        },
        {
          "name": "Login User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"sandrodev\",\n  \"password\": \"SecurePass123!\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "description": "Inicia sesión y obtiene token JWT"
        }
      ]
    },
    {
      "name": "Tools",
      "item": [
        {
          "name": "Get All Tools",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tools",
              "host": ["{{base_url}}"],
              "path": ["api", "tools"]
            }
          },
          "description": "Lista todas las herramientas (público)"
        },
        {
          "name": "Get Tool by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tools/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id"]
            }
          },
          "description": "Obtiene detalle de una herramienta (público)"
        },
        {
          "name": "Create Tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Visual Studio Code\",\n  \"description\": \"Editor de código fuente gratuito y multiplataforma desarrollado por Microsoft\",\n  \"url\": \"https://code.visualstudio.com/\",\n  \"category_id\": 1\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tools",
              "host": ["{{base_url}}"],
              "path": ["api", "tools"]
            }
          },
          "description": "Crea una nueva herramienta (requiere JWT)"
        },
        {
          "name": "Update Tool",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"VS Code Updated\",\n  \"description\": \"Editor de código actualizado con más funcionalidades\",\n  \"url\": \"https://code.visualstudio.com/\",\n  \"category_id\": 2\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tools/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id"]
            }
          },
          "description": "Actualiza una herramienta existente (requiere JWT)"
        },
        {
          "name": "Delete Tool",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tools/:id",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id"]
            }
          },
          "description": "Elimina una herramienta (requiere JWT)"
        },
        {
          "name": "Toggle Favorite",
          "request": {
            "method": "PATCH",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tools/:id/favorite",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id", "favorite"]
            }
          },
          "description": "Alterna el estado de favorito (requiere JWT)"
        },
        {
          "name": "Upload Tool Image",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tools/:id/image",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id", "image"]
            }
          },
          "description": "Sube una imagen para la herramienta (requiere JWT, multipart/form-data)"
        },
        {
          "name": "Delete Tool Image",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/tools/:id/image",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id", "image"]
            }
          },
          "description": "Elimina la imagen de una herramienta (requiere JWT)"
        },
        {
          "name": "Get GitHub Stats",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/tools/:id/github-stats",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id", "github-stats"]
            }
          },
          "description": "Obtiene estadísticas del repositorio GitHub (público)"
        },
        {
          "name": "Assign Tags to Tool",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tag_ids\": [1, 2, 3]\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/tools/:id/tags",
              "host": ["{{base_url}}"],
              "path": ["api", "tools", ":id", "tags"]
            }
          },
          "description": "Asigna tags a una herramienta (requiere JWT)"
        }
      ]
    },
