{
	"info": {
		"_postman_id": "devtools-hub-collection",
		"name": "DevToolsHub API",
		"description": "Colección completa de la API DevToolsHub para gestión de herramientas de desarrollo",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
		"version": "1.0.0"
	},
	"variable": [
		{
			"key": "baseUrl",
			"value": "http://localhost:3000",
			"type": "string"
		},
		{
			"key": "token",
			"value": "",
			"type": "string",
			"description": "Token JWT obtenido al hacer login"
		}
	],
	"item": [
		{
			"name": "Autenticación",
			"description": "Endpoints para registro y login de usuarios",
			"item": [
				{
					"name": "Registrar usuario",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"usuario_demo\",\n  \"password\": \"ContraseñaSegura123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/register",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "register"]
						}
					},
					"response": []
				},
				{
					"name": "Iniciar sesión",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"username\": \"usuario_demo\",\n  \"password\": \"ContraseñaSegura123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/auth/login",
							"host": ["{{baseUrl}}"],
							"path": ["api", "auth", "login"]
						}
					},
					"response": [],
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"// Guardar el token en la variable de entorno",
									"var jsonData = pm.response.json();",
									"pm.environment.set('token', jsonData.token);",
									"",
									"pm.test(\"Login exitoso\", function () {",
									"    pm.response.to.have.status(200);",
									"    pm.expect(jsonData.token).to.be.a('string');",
									"    pm.expect(jsonData.user).to.be.an('object');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					]
				}
			]
		},
		{
			"name": "Herramientas (Tools)",
			"description": "CRUD completo para herramientas de desarrollo",
			"item": [
				{
					"name": "Listar todas las herramientas",
					"request": {
						"method": "GET",
						"header": [],
