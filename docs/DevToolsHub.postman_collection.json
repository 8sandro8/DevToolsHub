							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"nombre\": \"Next.js\",\n  \"descripcion\": \"Framework React con renderizado del lado del servidor\",\n  \"url\": \"https://nextjs.org\",\n  \"rating\": 5,\n  \"es_favorito\": true,\n  \"categories\": [1, 2],\n  \"tags\": [1, 3, 4]\n}"
						},
