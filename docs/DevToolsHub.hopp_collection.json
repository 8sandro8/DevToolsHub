{
  "version": "2.0.0",
  "name": "DevToolsHub API",
  "description": "Colección de requests para la API de DevToolsHub\n\nURL Base: {{baseUrl}}\n\nEsta colección incluye ejemplos para todos los endpoints del backend.",
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:4001/api",
      "type": "string"
    }
  ],
  "folders": [
    {
      "name": "Health",
      "id": "folder-health"
    },
    {
      "name": "Tools",
      "id": "folder-tools"
    },
    {
      "name": "Categories",
      "id": "folder-categories"
    }
  ],
  "requests": [
    {
      "id": "health-check",
      "name": "Health Check",
      "method": "GET",
      "url": "{{baseUrl}}/health",
      "description": "Verifica el estado de la API",
      "folder": "folder-health"
    },
    {
      "id": "tools-get-all",
      "name": "Get All Tools",
      "method": "GET",
      "url": "{{baseUrl}}/tools?buscar=&categoria=&favorito=&page=1&limit=10",
      "description": "Obtiene todas las herramientas con filtros opcionales",
      "folder": "folder-tools"
    },
    {
      "id": "tools-get-by-id",
      "name": "Get Tool by ID",
      "method": "GET",
      "url": "{{baseUrl}}/tools/:id",
      "description": "Obtiene una herramienta específica por su ID",
      "folder": "folder-tools"
    },
    {
      "id": "tools-create",
      "name": "Create Tool",
      "method": "POST",
      "url": "{{baseUrl}}/tools",
      "description": "Crea una nueva herramienta",
      "folder": "folder-tools",
      "header": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": "{\n  \"nombre\": \"VS Code\",\n  \"descripcion\": \"Editor de código fuente gratuito y multiplataforma desarrollado por Microsoft\",\n  \"url\": \"https://code.visualstudio.com/\",\n  \"rating\": 5,\n  \"es_favorito\": true,\n  \"categories\": [1, 2]\n}"
    },
    {
      "id": "tools-update",
      "name": "Update Tool",
      "method": "PUT",
      "url": "{{baseUrl}}/tools/:id",
      "description": "Actualiza una herramienta existente",
      "folder": "folder-tools",
      "header": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": "{\n  \"nombre\": \"VS Code Updated\",\n  \"descripcion\": \"Descripción actualizada del editor\",\n  \"url\": \"https://code.visualstudio.com/\",\n  \"rating\": 4,\n  \"es_favorito\": false,\n  \"categories\": [1]\n}"
    },
    {
      "id": "tools-delete",
      "name": "Delete Tool",
      "method": "DELETE",
      "url": "{{baseUrl}}/tools/:id",
      "description": "Archiva (soft delete) una herramienta",
      "folder": "folder-tools"
    },
    {
      "id": "tools-toggle-favorite",
      "name": "Toggle Favorite",
      "method": "PATCH",
      "url": "{{baseUrl}}/tools/:id/favorito",
      "description": "Alterna el estado de favorito de una herramienta",
      "folder": "folder-tools"
    },
    {
      "id": "categories-get-all",
      "name": "Get All Categories",
      "method": "GET",
      "url": "{{baseUrl}}/categories",
      "description": "Obtiene todas las categorías",
      "folder": "folder-categories"
    },
    {
      "id": "categories-get-by-id",
      "name": "Get Category by ID",
      "method": "GET",
      "url": "{{baseUrl}}/categories/:id",
      "description": "Obtiene una categoría específica por su ID",
      "folder": "folder-categories"
    },
    {
      "id": "categories-create",
      "name": "Create Category",
      "method": "POST",
      "url": "{{baseUrl}}/categories",
      "description": "Crea una nueva categoría",
      "folder": "folder-categories",
      "header": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": "{\n  \"nombre\": \"Desarrollo Web\",\n  \"color\": \"#3b82f6\"\n}"
    },
    {
      "id": "categories-update",
      "name": "Update Category",
      "method": "PUT",
      "url": "{{baseUrl}}/categories/:id",
      "description": "Actualiza una categoría existente",
      "folder": "folder-categories",
      "header": [
        {
          "key": "Content-Type",
          "value": "application/json"
        }
      ],
      "body": "{\n  \"nombre\": \"Desarrollo Web Actualizado\",\n  \"color\": \"#2563eb\"\n}"
    },
    {
      "id": "categories-delete",
      "name": "Delete Category",
      "method": "DELETE",
      "url": "{{baseUrl}}/categories/:id",
      "description": "Elimina una categoría",
      "folder": "folder-categories"
    }
  ]
}